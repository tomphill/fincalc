{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "formatter": true,
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GHPAT}",
      },
    },
  },
}
